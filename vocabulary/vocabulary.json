{
  "name": "Bitstamp API Vocabulary",
  "description": "Key terms, operations, and data properties from the Bitstamp API",
  "tags": [
    "Market Data"
  ],
  "operations": [
    {
      "id": "getticker",
      "summary": "Get ticker data",
      "path": "/api/v2/ticker/{currency_pair}/",
      "method": "GET"
    },
    {
      "id": "gethourlyticker",
      "summary": "Get hourly ticker data",
      "path": "/api/v2/ticker_hour/{currency_pair}/",
      "method": "GET"
    },
    {
      "id": "getorderbook",
      "summary": "Get order book",
      "path": "/api/v2/order_book/{currency_pair}/",
      "method": "GET"
    },
    {
      "id": "gettransactions",
      "summary": "Get recent transactions",
      "path": "/api/v2/transactions/{currency_pair}/",
      "method": "GET"
    },
    {
      "id": "gettradingpairsinfo",
      "summary": "Get trading pairs info",
      "path": "/api/v2/trading-pairs-info/",
      "method": "GET"
    },
    {
      "id": "getohlcdata",
      "summary": "Get OHLC data",
      "path": "/api/v2/ohlc/{currency_pair}/",
      "method": "GET"
    },
    {
      "id": "getcurrencies",
      "summary": "Get available currencies",
      "path": "/api/v2/currencies/",
      "method": "GET"
    }
  ],
  "parameters": [
    "currency_pair",
    "end",
    "exclude_current_candle",
    "group",
    "limit",
    "start",
    "step",
    "time"
  ],
