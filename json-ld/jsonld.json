  "@type": "schema:WebAPI",
  "@id": "https://www.bitstamp.net/api/",
  "schema:name": "Bitstamp API",
  "schema:description": "Bitstamp cryptocurrency exchange REST API providing market data including tickers, order books, transactions, OHLC data, and trading pair information.",
  "schema:version": "2.0.0",
  "schema:provider": {
    "@type": "schema:Organization",
    "schema:name": "Bitstamp",
    "schema:url": "https://www.bitstamp.net"
  },
  "schema:documentation": "https://www.bitstamp.net/api/",
  "schema:termsOfService": "https://www.bitstamp.net/terms-of-use/",
  "bitstamp:endpoints": [
    {
      "@type": "schema:EntryPoint",
      "@id": "https://www.bitstamp.net/api/v2/ticker/{currency_pair}/",
      "schema:name": "Get ticker data",
      "schema:description": "Returns ticker data for the specified currency pair including last price, bid, ask, volume, and 24-hour statistics.",
      "schema:httpMethod": "GET"
    },
    {
      "@type": "schema:EntryPoint",
      "@id": "https://www.bitstamp.net/api/v2/ticker_hour/{currency_pair}/",
      "schema:name": "Get hourly ticker data",
      "schema:description": "Returns hourly ticker data for the specified currency pair.",
      "schema:httpMethod": "GET"
    },
    {
      "@type": "schema:EntryPoint",
      "@id": "https://www.bitstamp.net/api/v2/order_book/{currency_pair}/",
      "schema:name": "Get order book",
      "schema:description": "Returns a JSON dictionary with bids and asks lists of open orders for the specified currency pair.",
      "schema:httpMethod": "GET"
    },
    {
      "@type": "schema:EntryPoint",
      "@id": "https://www.bitstamp.net/api/v2/transactions/{currency_pair}/",
      "schema:name": "Get recent transactions",
      "schema:description": "Returns a descending list of recent transactions for the specified currency pair.",
      "schema:httpMethod": "GET"
    },
    {
      "@type": "schema:EntryPoint",
      "@id": "https://www.bitstamp.net/api/v2/trading-pairs-info/",
      "schema:name": "Get trading pairs info",
      "schema:description": "Returns a list of all available trading pairs with their details including minimum order size and decimal precision.",
      "schema:httpMethod": "GET"
    },
    {
      "@type": "schema:EntryPoint",
      "@id": "https://www.bitstamp.net/api/v2/ohlc/{currency_pair}/",
      "schema:name": "Get OHLC data",
      "schema:description": "Returns OHLC (Open, High, Low, Close) candlestick data for the specified currency pair.",
      "schema:httpMethod": "GET"
    },
    {
      "@type": "schema:EntryPoint",
      "@id": "https://www.bitstamp.net/api/v2/currencies/",
      "schema:name": "Get available currencies",
      "schema:description": "Returns a list of available currencies.",
      "schema:httpMethod": "GET"
    }
  ]
}